#!/usr/bin/env python3
"""kri — CLI bridge to the kritamcp plugin running inside Krita.

JSON-over-HTTP to the plugin (default http://localhost:5678). Stdlib only,
so every invocation starts fast and there is no venv.

Env:
  KRITA_URL       plugin endpoint (default http://localhost:5678)
  KRITAMCP_TOKEN  shared token; must match the token set in Krita's env
  KRI_LOOK_PATH   override the default image path used by `kri look`

Exit codes: 0 ok · 1 plugin/connection error · 2 usage error.
"""
import argparse
import base64
import json
import os
import sys
import time
import urllib.error
import urllib.request

KRITA_URL = os.environ.get("KRITA_URL", "http://localhost:5678")
TOKEN = os.environ.get("KRITAMCP_TOKEN", "")

WORKSPACES = ["generation", "upscaling", "live", "animation", "custom"]
JOB_STATES = ["all", "queued", "executing", "finished", "cancelled"]
CONTROL_MODES = [
    "scribble", "line_art", "soft_edge", "canny_edge", "depth", "normal",
    "pose", "segmentation", "blur", "stencil",
    "reference", "style", "composition", "face",
]


def send(action, params=None, timeout=30.0):
    """POST one command. The timeout also travels in the body so the plugin
    stops waiting just before we would (same contract server.py used)."""
    body = json.dumps(
        {"action": action, "params": params or {}, "timeout": timeout}
    ).encode()
    headers = {"Content-Type": "application/json"}
    if TOKEN:
        headers["X-Kritamcp-Token"] = TOKEN
    req = urllib.request.Request(KRITA_URL, data=body, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        try:
            return json.loads(e.read().decode())
        except Exception:
            return {"error": f"HTTP {e.code} from plugin"}
    except urllib.error.URLError as e:
        return {"error": (f"Cannot connect to Krita at {KRITA_URL} — is Krita "
                          f"running with the kritamcp plugin? ({e.reason})")}
    except Exception as e:
        return {"error": str(e)}


def out(result):
    """Print result as JSON and exit. Errors go to stderr with exit code 1 so
    `kri a && kri b` chains stop at the first failure."""
    text = json.dumps(result, indent=1, default=str)
    if isinstance(result, dict) and result.get("error"):
        print(text, file=sys.stderr)
        sys.exit(1)
    print(text)
    sys.exit(0)


def clean(**params):
    """Drop None values so the plugin's own defaults apply."""
    return {k: v for k, v in params.items() if v is not None}


def write_image(payload, path):
    """Decode a plugin canvas payload (data_b64) to a file; return summary."""
    raw = base64.b64decode(payload["data_b64"])
    with open(path, "wb") as f:
        f.write(raw)
    return {"path": path, "width": payload.get("width"),
            "height": payload.get("height"), "format": payload.get("format")}


def look_path(payload, override):
    if override:
        return override
    ext = "png" if payload.get("format") == "png" else "jpg"
    return os.environ.get("KRI_LOOK_PATH") or f"/tmp/kri-canvas.{ext}"


def parse_points(tokens):
    pts = []
    for t in tokens:
        try:
            x, y = t.split(",")
            pts.append([int(x), int(y)])
        except ValueError:
            print(f"kri: invalid point '{t}' (expected X,Y)", file=sys.stderr)
            sys.exit(2)
    return pts


def read_source(file_arg):
    if file_arg == "-":
        return sys.stdin.read()
    with open(file_arg) as f:
        return f.read()


# ----- handlers -----

def cmd_health(a):
    headers = {"X-Kritamcp-Token": TOKEN} if TOKEN else {}
    req = urllib.request.Request(f"{KRITA_URL}/health", headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=5) as r:
            out(json.loads(r.read().decode()))
    except Exception as e:
        out({"error": f"Cannot connect to Krita at {KRITA_URL}: {e}"})


def cmd_status(a):
    """Document + full AI overview in ONE round-trip via the plugin's batch."""
    res = send("batch", {"commands": [{"action": "doc_info"},
                                      {"action": "ai_overview"}]}, timeout=30.0)
    if not isinstance(res, dict) or res.get("error"):
        out(res)
    results = (res.get("results") or []) + [{}, {}]
    doc_res, ai_res = results[0] or {}, results[1] or {}
    merged = {}
    merged["doc"] = (doc_res.get("document") if not doc_res.get("error")
                     else {"error": doc_res["error"]})
    if not ai_res.get("error"):
        merged.update({k: v for k, v in ai_res.items() if k != "status"})
    else:
        merged["ai"] = {"error": ai_res["error"]}
    out(merged)


def cmd_undo(a):
    out(send("undo"))


def cmd_canvas(a):
    out(send("new_canvas", {"width": a.width, "height": a.height,
                            "name": a.name, "background": a.bg}))


def cmd_color(a):
    out(send("set_color", {"color": a.color}))


def cmd_brush(a):
    out(send("set_brush", clean(preset=a.preset, size=a.size, opacity=a.opacity)))


def cmd_stroke(a):
    out(send("stroke", clean(points=parse_points(a.points), size=a.size,
                             feather=a.feather, opacity=a.opacity)))


def cmd_fill(a):
    out(send("fill", {"x": a.x, "y": a.y, "radius": a.radius,
                      "feather": a.feather}))


def cmd_shape(a):
    out(send("draw_shape", clean(shape=a.shape, x=a.x, y=a.y, width=a.width,
                                 height=a.height, fill=not a.no_fill,
                                 stroke=a.stroke, feather=a.feather,
                                 x2=a.x2, y2=a.y2, line_width=a.line_width)))


def cmd_redo(a):
    out(send("redo"))


def cmd_clear(a):
    out(send("clear", {"color": a.color}))


def cmd_save(a):
    out(send("save", {"path": os.path.abspath(a.path)}, timeout=120.0))


def cmd_open(a):
    out(send("open_file", {"path": os.path.abspath(a.path)}))


def cmd_color_at(a):
    out(send("get_color_at", {"x": a.x, "y": a.y}))


def cmd_brushes(a):
    out(send("list_brushes", {"filter": a.filter, "limit": a.limit}))


def cmd_look(a):
    mode = "full" if a.full else "fast"
    res = send("get_canvas", clean(mode=mode, max_dim=a.max_dim), timeout=120.0)
    if not isinstance(res, dict) or res.get("error"):
        out(res)
    out(write_image(res, look_path(res, a.out)))


def cmd_batch(a):
    try:
        commands = json.loads(read_source(a.file))
    except json.JSONDecodeError as e:
        print(f"kri: invalid batch JSON: {e}", file=sys.stderr)
        sys.exit(2)
    if isinstance(commands, dict):
        commands = [commands]
    res = send("batch",
               clean(commands=commands, review=a.look, stop_on_error=True),
               timeout=120.0)
    if not isinstance(res, dict) or res.get("error"):
        out(res)
    canvas = res.pop("canvas", None)
    if a.look and isinstance(canvas, dict) and canvas.get("data_b64"):
        res["canvas"] = write_image(canvas, look_path(canvas, a.out))
    if res.get("stopped_at") is not None:
        res["error"] = f"batch stopped at command {res['stopped_at']}"
    out(res)


def cmd_exec(a):
    code = read_source(a.file)
    out(send("exec", {"code": code}, timeout=a.timeout))


# ----- AI Diffusion -----

def cmd_ai_status(a):
    out(send("ai_status"))


def cmd_ai_overview(a):
    out(send("ai_overview"))


def cmd_ai_set_prompt(a):
    if a.positive is None and a.negative is None:
        print("kri: provide -p/--positive and/or -n/--negative", file=sys.stderr)
        sys.exit(2)
    out(send("ai_set_prompt", clean(positive=a.positive, negative=a.negative)))


def cmd_ai_set_params(a):
    params = clean(style=a.style, strength=a.strength, seed=a.seed,
                   fixed_seed=a.fixed_seed, batch_count=a.batch_count)
    if not params:
        print("kri: provide at least one parameter", file=sys.stderr)
        sys.exit(2)
    out(send("ai_set_params", params))


def cmd_ai_workspace(a):
    out(send("ai_set_workspace", {"name": a.name}))


def cmd_ai_generate(a):
    res = send("ai_generate")
    if not isinstance(res, dict) or res.get("error") or not a.wait:
        out(res)
    deadline = time.time() + a.timeout
    last = None
    while time.time() < deadline:
        time.sleep(a.poll)
        st = send("ai_status")
        if not isinstance(st, dict) or st.get("error"):
            out(st)
        last = st
        q = st.get("queue") or {}
        if not q.get("queued") and not q.get("executing"):
            out({"status": "ok", "generate": res, "final": st})
    out({"error": f"still generating after {a.timeout}s", "last_status": last})


def cmd_ai_jobs(a):
    out(send("ai_list_jobs", {"state": a.state, "limit": a.limit}))


def cmd_ai_apply(a):
    out(send("ai_apply", clean(job_id=a.job_id, index=a.index)))


def cmd_ai_cancel(a):
    out(send("ai_cancel", {"active": True, "queued": a.queued}))


def cmd_ai_preview(a):
    out(send("ai_save_preview", {"job_id": a.job_id, "index": a.index,
                                 "filename": a.filename}))


def cmd_ai_styles(a):
    out(send("ai_list_styles", {"filter": a.filter, "limit": a.limit}))


def cmd_region_create(a):
    out(send("ai_create_region", {"positive": a.positive, "group": a.group}))


def cmd_region_list(a):
    out(send("ai_list_regions"))


def cmd_region_select(a):
    out(send("ai_select_region", clean(index=a.index, layer_id=a.layer_id)))


def cmd_region_remove(a):
    out(send("ai_remove_region", {"index": a.index}))


def cmd_control_add(a):
    out(send("ai_add_control", clean(mode=a.mode, layer_id=a.layer_id,
                                     strength=a.strength, region_index=a.region)))


def cmd_control_list(a):
    out(send("ai_list_controls", clean(region_index=a.region)))


def cmd_control_set(a):
    out(send("ai_set_control", clean(index=a.index, mode=a.mode,
                                     strength=a.strength, region_index=a.region)))


def cmd_control_remove(a):
    out(send("ai_remove_control", clean(index=a.index, region_index=a.region)))


def build_parser():
    p = argparse.ArgumentParser(
        prog="kri",
        description="CLI bridge to Krita (kritamcp plugin). Prints JSON; errors exit 1.",
    )
    sub = p.add_subparsers(dest="cmd", required=True, metavar="command")

    sp = sub.add_parser("health", help="check the plugin is up")
    sp.set_defaults(fn=cmd_health)

    sp = sub.add_parser("status", help="document + full AI state in one round-trip")
    sp.set_defaults(fn=cmd_status)

    sp = sub.add_parser("undo", help="undo last action")
    sp.set_defaults(fn=cmd_undo)

    sp = sub.add_parser("canvas", help="create a new canvas: kri canvas W H")
    sp.add_argument("width", type=int)
    sp.add_argument("height", type=int)
    sp.add_argument("--name", default="New Canvas")
    sp.add_argument("--bg", default="#1a1a2e")
    sp.set_defaults(fn=cmd_canvas)

    sp = sub.add_parser("color", help="set foreground color (hex)")
    sp.add_argument("color")
    sp.set_defaults(fn=cmd_color)

    sp = sub.add_parser("brush", help="set brush preset/size/opacity")
    sp.add_argument("--preset")
    sp.add_argument("--size", type=int)
    sp.add_argument("--opacity", type=float)
    sp.set_defaults(fn=cmd_brush)

    sp = sub.add_parser("stroke", help="polyline: kri stroke 100,100 150,120")
    sp.add_argument("points", nargs="+", metavar="X,Y")
    sp.add_argument("--size", type=int)
    sp.add_argument("--feather", type=float, default=0.0)
    sp.add_argument("--opacity", type=float, default=1.0)
    sp.set_defaults(fn=cmd_stroke)

    sp = sub.add_parser("fill", help="fill a circle: kri fill X Y [RADIUS]")
    sp.add_argument("x", type=int)
    sp.add_argument("y", type=int)
    sp.add_argument("radius", type=int, nargs="?", default=50)
    sp.add_argument("--feather", type=float, default=0.0)
    sp.set_defaults(fn=cmd_fill)

    sp = sub.add_parser("shape", help="draw rectangle/ellipse/line")
    sp.add_argument("shape", choices=["rectangle", "ellipse", "line"])
    sp.add_argument("x", type=int)
    sp.add_argument("y", type=int)
    sp.add_argument("width", type=int, nargs="?", default=100)
    sp.add_argument("height", type=int, nargs="?", default=100)
    sp.add_argument("--no-fill", action="store_true")
    sp.add_argument("--stroke", action="store_true")
    sp.add_argument("--feather", type=float, default=0.0)
    sp.add_argument("--x2", type=int)
    sp.add_argument("--y2", type=int)
    sp.add_argument("--line-width", type=int, dest="line_width")
    sp.set_defaults(fn=cmd_shape)

    sp = sub.add_parser("redo", help="redo last undone action")
    sp.set_defaults(fn=cmd_redo)

    sp = sub.add_parser("clear", help="clear canvas to a color")
    sp.add_argument("color", nargs="?", default="#1a1a2e")
    sp.set_defaults(fn=cmd_clear)

    sp = sub.add_parser("save", help="export canvas to a file")
    sp.add_argument("path")
    sp.set_defaults(fn=cmd_save)

    sp = sub.add_parser("open", help="open a file in Krita")
    sp.add_argument("path")
    sp.set_defaults(fn=cmd_open)

    sp = sub.add_parser("color-at", help="eyedropper at X Y")
    sp.add_argument("x", type=int)
    sp.add_argument("y", type=int)
    sp.set_defaults(fn=cmd_color_at)

    sp = sub.add_parser("brushes", help="list brush presets")
    sp.add_argument("filter", nargs="?", default="")
    sp.add_argument("--limit", type=int, default=20)
    sp.set_defaults(fn=cmd_brushes)

    sp = sub.add_parser("look", help="save canvas image to a file, print its path")
    sp.add_argument("--full", action="store_true",
                    help="full-res PNG (default: fast downscaled JPEG)")
    sp.add_argument("--max-dim", type=int, default=1024, dest="max_dim")
    sp.add_argument("-o", "--out")
    sp.set_defaults(fn=cmd_look)

    sp = sub.add_parser("batch",
                        help="run many commands in one round-trip (JSON file or stdin)")
    sp.add_argument("file", nargs="?", default="-")
    sp.add_argument("--look", choices=["fast", "full"],
                    help="also return the final canvas image")
    sp.add_argument("-o", "--out")
    sp.set_defaults(fn=cmd_batch)

    sp = sub.add_parser("exec",
                        help="run Python inside Krita (needs KRITAMCP_ALLOW_EXEC=1)")
    sp.add_argument("file", nargs="?", default="-",
                    help="script path, or '-' for stdin (default)")
    sp.add_argument("--timeout", type=float, default=30.0)
    sp.set_defaults(fn=cmd_exec)

    ai = sub.add_parser("ai", help="AI Diffusion plugin").add_subparsers(
        dest="ai_cmd", required=True, metavar="ai-command")

    sp = ai.add_parser("status", help="AI state (connection/style/queue/prompt)")
    sp.set_defaults(fn=cmd_ai_status)

    sp = ai.add_parser("overview", help="raw ai_overview (kri status merges this)")
    sp.set_defaults(fn=cmd_ai_overview)

    sp = ai.add_parser("set-prompt")
    sp.add_argument("-p", "--positive")
    sp.add_argument("-n", "--negative")
    sp.set_defaults(fn=cmd_ai_set_prompt)

    sp = ai.add_parser("set-params")
    sp.add_argument("--style")
    sp.add_argument("--strength", type=float)
    sp.add_argument("--seed", type=int)
    sp.add_argument("--fixed-seed", action=argparse.BooleanOptionalAction,
                    dest="fixed_seed", default=None)
    sp.add_argument("--batch-count", type=int, dest="batch_count")
    sp.set_defaults(fn=cmd_ai_set_params)

    sp = ai.add_parser("workspace")
    sp.add_argument("name", choices=WORKSPACES)
    sp.set_defaults(fn=cmd_ai_workspace)

    sp = ai.add_parser("generate")
    sp.add_argument("--wait", action="store_true",
                    help="block until the job queue drains")
    sp.add_argument("--timeout", type=float, default=300.0)
    sp.add_argument("--poll", type=float, default=2.0,
                    help="seconds between status polls (with --wait)")
    sp.set_defaults(fn=cmd_ai_generate)

    sp = ai.add_parser("jobs")
    sp.add_argument("--state", choices=JOB_STATES, default="all")
    sp.add_argument("--limit", type=int, default=20)
    sp.set_defaults(fn=cmd_ai_jobs)

    sp = ai.add_parser("apply", help="apply a finished result to the canvas")
    sp.add_argument("--job-id", dest="job_id")
    sp.add_argument("--index", type=int, default=0)
    sp.set_defaults(fn=cmd_ai_apply)

    sp = ai.add_parser("cancel")
    sp.add_argument("--queued", action="store_true",
                    help="also cancel queued (not started) jobs")
    sp.set_defaults(fn=cmd_ai_cancel)

    sp = ai.add_parser("preview", help="save a result image without applying it")
    sp.add_argument("job_id")
    sp.add_argument("--index", type=int, default=0)
    sp.add_argument("--filename", default="")
    sp.set_defaults(fn=cmd_ai_preview)

    sp = ai.add_parser("styles")
    sp.add_argument("filter", nargs="?", default="")
    sp.add_argument("--limit", type=int, default=30)
    sp.set_defaults(fn=cmd_ai_styles)

    region = ai.add_parser("region", help="region masks").add_subparsers(
        dest="region_cmd", required=True)
    sp = region.add_parser("create")
    sp.add_argument("-p", "--positive", default="")
    sp.add_argument("--group", action="store_true")
    sp.set_defaults(fn=cmd_region_create)
    sp = region.add_parser("list")
    sp.set_defaults(fn=cmd_region_list)
    sp = region.add_parser("select", help="no index = select root")
    sp.add_argument("index", type=int, nargs="?")
    sp.add_argument("--layer-id", dest="layer_id")
    sp.set_defaults(fn=cmd_region_select)
    sp = region.add_parser("remove")
    sp.add_argument("index", type=int)
    sp.set_defaults(fn=cmd_region_remove)

    control = ai.add_parser("control", help="ControlNet / IP-Adapter layers"
                            ).add_subparsers(dest="control_cmd", required=True)
    sp = control.add_parser("add")
    sp.add_argument("mode", choices=CONTROL_MODES)
    sp.add_argument("--layer-id", dest="layer_id")
    sp.add_argument("--strength", type=float)
    sp.add_argument("--region", type=int)
    sp.set_defaults(fn=cmd_control_add)
    sp = control.add_parser("list")
    sp.add_argument("--region", type=int)
    sp.set_defaults(fn=cmd_control_list)
    sp = control.add_parser("set")
    sp.add_argument("index", type=int)
    sp.add_argument("--mode", choices=CONTROL_MODES)
    sp.add_argument("--strength", type=float)
    sp.add_argument("--region", type=int)
    sp.set_defaults(fn=cmd_control_set)
    sp = control.add_parser("remove")
    sp.add_argument("index", type=int)
    sp.add_argument("--region", type=int)
    sp.set_defaults(fn=cmd_control_remove)

    return p


def main():
    args = build_parser().parse_args()
    args.fn(args)


if __name__ == "__main__":
    main()
